Windows Registry Editor Version 5.00

; Removes the " - Shortcut" text that is appended to shortcuts

; 1. Reset the legacy binary 'link' value to zeros
[HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Explorer]
"link"=hex:00,00,00,00

; 2. Explicitly define the naming template to exclude the suffix
[HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Explorer\NamingTemplates]
"ShortcutNameTemplate"="%s.lnk"
